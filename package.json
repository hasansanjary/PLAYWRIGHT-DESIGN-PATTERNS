    "test:realworld:debug": "npx playwright test e2e/tests/FPM-Realworld-Login/FPM-Realworld.spec.ts --debug",
    "test:realworld:trace": "npx playwright test e2e/tests/FPM-Realworld-Login/FPM-Realworld.spec.ts --trace=on",
    "test:realworld:report": "npx playwright show-report",
    "test:realworld:chrome": "npx playwright test e2e/tests/FPM-Realworld-Login/FPM-Realworld.spec.ts --headed --project=chromium",
    "test:realworld:firefox": "npx playwright test e2e/tests/FPM-Realworld-Login/FPM-Realworld.spec.ts --headed --project=firefox",
    "test:realworld:webkit": "npx playwright test e2e/tests/FPM-Realworld-Login/FPM-Realworld.spec.ts --headed --project=webkit",
    "test:realworld:mobile-chrome": "npx playwright test e2e/tests/FPM-Realworld-Login/FPM-Realworld.spec.ts --headed --project=Mobile Chrome",
    "test:realworld:mobile-safari": "npx playwright test e2e/tests/FPM-Realworld-Login/FPM-Realworld.spec.ts --headed --project='Mobile Safari'",
    "test:realworld:all": "npx playwright test e2e/tests/FPM-Realworld-Login/FPM-Realworld.spec.ts --headed --project=chromium --project=firefox --project=webkit --project='Mobile Chrome' --project='Mobile Safari'",
    "test:login": "npx playwright test e2e/tests/POM-Login-TestExamples/login.spec.ts --headed",
    "test:cross-browser": "npx playwright test e2e/tests/cross_browser_Test/cross-browser.spec.ts --headed",
    "test:fixtures": "npx playwright test e2e/tests/Fixtures/browser_context_page_fixtures.spec.ts --headed",
    "test:checkbox": "npx playwright test e2e/tests/Lamdatest/checkboxes.spec.ts --headed"
  },
